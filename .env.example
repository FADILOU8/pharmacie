APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# Increase bcrypt cost factor for stronger password hashing (12–14 recommended for production).
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Set to 'error' in production to avoid leaking stack traces into logs.
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pharmacy
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Session Security
# All options below harden session cookies for a production HTTPS deployment.
# ---------------------------------------------------------------------------

SESSION_DRIVER=file
SESSION_LIFETIME=120

# Encrypt all session data at rest using the APP_KEY (AES-256-CBC).
SESSION_ENCRYPT=true

SESSION_PATH=/
SESSION_DOMAIN=null

# Only transmit the session cookie over HTTPS connections.
SESSION_SECURE_COOKIE=true

# Prevent JavaScript from reading the session cookie (mitigates XSS cookie theft).
SESSION_HTTP_ONLY=true

# Restrict the cookie to same-site requests to block CSRF from cross-origin forms.
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
